# =============================================================================
# AGENT SLAM 2026 — Environment Configuration
# =============================================================================
# HOW TO USE:
#   1. Copy this file and rename it to .env  (never commit .env to GitHub)
#   2. Fill in every value below before running the agent
#   3. All values come from the competition admin — details explained per field
# =============================================================================


# -----------------------------------------------------------------------------
# ANTHROPIC API KEY
# -----------------------------------------------------------------------------
# This is the secret key that lets your agent call the Claude AI model.
# WHERE TO GET IT:
#   1. Go to https://console.anthropic.com
#   2. Sign in or create a free account
#   3. Click "API Keys" in the left sidebar
#   4. Click "Create Key", give it a name (e.g. agent-slam), copy the key
# NOTE: The key starts with "sk-ant-". Never share it or commit it to GitHub.
ANTHROPIC_API_KEY=sk-ant-your-key-here


# -----------------------------------------------------------------------------
# LIVE MATCH WEBSOCKET URL
# -----------------------------------------------------------------------------
# This is the WebSocket address your agent connects to during a real match.
# WHERE TO GET IT:
#   - The competition admin will send this to your registered email address
#     when your match is activated (status goes from pending → active).
#   - You will also see it inside the match dashboard on the competition website.
# FORMAT: It looks like: ws://someserver.com/match/your-match-id
#         or: wss://someserver.com/... (secure version)
# NOTE: This changes every match — update it before each new match.
WS_URL=


# -----------------------------------------------------------------------------
# SANDBOX WEBSOCKET URL
# -----------------------------------------------------------------------------
# This is a separate test WebSocket URL for practice/validation before your match.
# WHERE TO GET IT:
#   - The admin provides this along with your login credentials.
#   - It is mentioned in the welcome email or the participant dashboard.
# HOW TO USE IT:
#   - Run: python agent.py --sandbox
#   - The sandbox does NOT affect your score or leaderboard — safe to test freely.
#   - Sandbox sessions auto-disconnect after 10 minutes.
# NOTE: Test here at least once before your real match to confirm everything works.
SANDBOX_WS_URL=


# -----------------------------------------------------------------------------
# TEAM EMAIL
# -----------------------------------------------------------------------------
# The email address your team registered with for Agent SLAM 2026.
# WHERE TO GET IT:
#   - This is the login email the admin assigned to your team.
#   - Check the registration confirmation email or ask your admin.
# PURPOSE: Used for the authentication handshake when connecting to the server.
TEAM_EMAIL=


# -----------------------------------------------------------------------------
# TEAM PASSWORD
# -----------------------------------------------------------------------------
# The password for your team's competition account.
# WHERE TO GET IT:
#   - Provided by the admin along with your login email (check your inbox).
#   - If you have not received it, contact the competition admin before match day.
# NOTE: Do not change this unless the admin resets it for you.
TEAM_PASSWORD=


# -----------------------------------------------------------------------------
# TEAM NAME
# -----------------------------------------------------------------------------
# Your team's identifier on the competition server — exactly as assigned.
# WHERE TO GET IT:
#   - The admin tells you this when they activate your match.
#   - It will be either "team1" or "team2" (all lowercase, no spaces).
#   - You can also see it in the match-state message your agent receives:
#       { "data": { "team1": "...", "team2": "..." } }
#     Your team name is whichever slot you are assigned to.
# IMPORTANT: This must match EXACTLY what the server uses — case-sensitive.
#   Correct:   team1   or   team2
#   Wrong:     Team1 / TEAM1 / Team 1
# NOTE: This changes per match if you are re-assigned — always double-check.
TEAM_NAME=
